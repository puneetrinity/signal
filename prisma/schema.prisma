generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ai_fit_jobs {
  id              Int           @id @default(autoincrement())
  bull_job_id     String        @unique(map: "ai_fit_jobs_bull_job_id_idx")
  queue_name      String
  user_id         Int
  application_id  Int?
  application_ids Int[]
  status          String        @default("pending")
  progress        Int?          @default(0)
  processed_count Int?          @default(0)
  total_count     Int?
  result          Json?
  error           String?
  error_code      String?
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  started_at      DateTime?     @db.Timestamp(6)
  completed_at    DateTime?     @db.Timestamp(6)
  applications    applications? @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([application_id])
  @@index([created_at])
  @@index([user_id, status], map: "ai_fit_jobs_user_status_idx")
}

model application_feedback {
  id             Int          @id @default(autoincrement())
  application_id Int
  author_id      Int
  overall_score  Int
  recommendation String
  notes          String?
  created_at     DateTime     @default(now()) @db.Timestamp(6)
  updated_at     DateTime     @default(now()) @db.Timestamp(6)
  applications   applications @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users        @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([application_id])
  @@index([author_id])
}

model application_graph_sync_jobs {
  id                      Int            @id @default(autoincrement())
  application_id          Int            @unique
  organization_id         Int?
  job_id                  Int
  effective_recruiter_id  Int
  status                  String         @default("pending")
  attempts                Int            @default(0)
  next_attempt_at         DateTime       @default(now()) @db.Timestamp(6)
  last_error              String?
  activekg_tenant_id      String
  activekg_parent_node_id String?
  chunk_count             Int?
  created_at              DateTime       @default(now()) @db.Timestamp(6)
  updated_at              DateTime       @default(now()) @db.Timestamp(6)
  applications            applications   @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                   users          @relation(fields: [effective_recruiter_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs                    jobs           @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations           organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organization_id], map: "app_graph_sync_org_idx")
  @@index([effective_recruiter_id], map: "app_graph_sync_recruiter_idx")
  @@index([status, next_attempt_at], map: "app_graph_sync_status_next_attempt_idx")
}

model application_stage_history {
  id             Int          @id @default(autoincrement())
  application_id Int
  from_stage     Int?
  to_stage       Int
  changed_by     Int
  notes          String?
  changed_at     DateTime     @default(now()) @db.Timestamp(6)
  applications   applications @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model applications {
  id                                               Int                          @id @default(autoincrement())
  job_id                                           Int
  user_id                                          Int?
  name                                             String
  email                                            String
  phone                                            String
  resume_url                                       String
  resume_filename                                  String?
  cover_letter                                     String?
  status                                           String                       @default("submitted")
  notes                                            String?
  last_viewed_at                                   DateTime?                    @db.Timestamp(6)
  downloaded_at                                    DateTime?                    @db.Timestamp(6)
  applied_at                                       DateTime                     @default(now()) @db.Timestamp(6)
  updated_at                                       DateTime                     @default(now()) @db.Timestamp(6)
  current_stage                                    Int?
  interview_date                                   DateTime?                    @db.Timestamp(6)
  interview_time                                   String?
  interview_location                               String?
  interview_notes                                  String?
  recruiter_notes                                  String[]
  rating                                           Int?
  tags                                             String[]
  stage_changed_at                                 DateTime?                    @db.Timestamp(6)
  stage_changed_by                                 Int?
  submitted_by_recruiter                           Boolean?                     @default(false)
  created_by_user_id                               Int?
  source                                           String?                      @default("public_apply")
  source_metadata                                  Json?
  ai_fit_score                                     Int?
  ai_fit_label                                     String?
  ai_fit_reasons                                   Json?
  ai_model_version                                 String?
  ai_computed_at                                   DateTime?                    @db.Timestamp(6)
  ai_stale_reason                                  String?
  ai_digest_version_used                           Int?
  ai_summary                                       String?
  ai_summary_version                               Int?                         @default(1)
  ai_suggested_action                              String?
  ai_suggested_action_reason                       String?
  ai_summary_computed_at                           DateTime?                    @db.Timestamp(6)
  resume_id                                        Int?
  rejection_reason                                 String?
  whatsapp_consent                                 Boolean                      @default(true)
  organization_id                                  Int?
  ai_summary_model_version                         String?
  ai_strengths                                     String[]
  ai_concerns                                      String[]
  ai_key_highlights                                String[]
  ai_required_skills_matched                       String[]
  ai_required_skills_missing                       String[]
  ai_required_skills_match_percentage              Int?
  ai_required_skills_depth_notes                   String?
  ai_good_to_have_skills_matched                   String[]
  ai_good_to_have_skills_missing                   String[]
  extracted_resume_text                            String?
  sync_skipped_reason                              String?
  hm_review_requested_at                           DateTime?                    @db.Timestamp(6)
  hm_review_requested_by                           Int?
  hm_review_note                                   String?
  platform_discovery_consent                       Boolean?                     @default(false)
  consent_captured_at                              DateTime?                    @db.Timestamp(6)
  ai_fit_jobs                                      ai_fit_jobs[]
  application_feedback                             application_feedback[]
  application_graph_sync_jobs                      application_graph_sync_jobs?
  application_stage_history                        application_stage_history[]
  users_applications_created_by_user_idTousers     users?                       @relation("applications_created_by_user_idTousers", fields: [created_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_applications_hm_review_requested_byTousers users?                       @relation("applications_hm_review_requested_byTousers", fields: [hm_review_requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs                                             jobs                         @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations                                    organizations?               @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  candidate_resumes                                candidate_resumes?           @relation(fields: [resume_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_applications_user_idTousers                users?                       @relation("applications_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  client_feedback                                  client_feedback[]
  client_shortlist_items                           client_shortlist_items[]
  email_audit_log                                  email_audit_log[]
  form_invitations                                 form_invitations[]
  form_responses                                   form_responses[]
  job_sourced_candidates                           job_sourced_candidates[]
  resume_import_items                              resume_import_items[]
  whatsapp_audit_log                               whatsapp_audit_log[]

  @@index([hm_review_requested_at])
  @@index([organization_id], map: "applications_org_idx")
  @@index([rejection_reason])
  @@index([status])
  @@index([user_id])
}

model automation_events {
  id              Int            @id @default(autoincrement())
  automation_key  String
  target_type     String
  target_id       Int
  outcome         String         @default("success")
  error_message   String?
  metadata        Json?
  triggered_at    DateTime       @default(now()) @db.Timestamp(6)
  triggered_by    Int?
  organization_id Int?
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users?         @relation(fields: [triggered_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([automation_key], map: "automation_events_key_idx")
  @@index([outcome])
  @@index([target_type])
  @@index([triggered_at])
}

model automation_settings {
  id              Int            @id @default(autoincrement())
  setting_key     String         @unique
  setting_value   Boolean        @default(true)
  description     String?
  updated_by      Int?
  updated_at      DateTime       @default(now()) @db.Timestamp(6)
  organization_id Int?
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model candidate_resumes {
  id             Int            @id @default(autoincrement())
  user_id        Int
  label          String
  gcs_path       String
  extracted_text String?
  is_default     Boolean?       @default(false)
  created_at     DateTime       @default(now()) @db.Timestamp(6)
  updated_at     DateTime       @default(now()) @db.Timestamp(6)
  applications   applications[]
  users          users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

model checkout_intents {
  id                                       Int                @id @default(autoincrement())
  email                                    String
  org_name                                 String
  user_id                                  Int?
  organization_id                          Int?
  plan_id                                  Int
  seats                                    Int                @default(1)
  billing_cycle                            String             @default("monthly")
  gstin                                    String?
  billing_name                             String?
  billing_address                          String?
  billing_city                             String?
  billing_state                            String?
  billing_pincode                          String?
  status                                   String             @default("pending")
  cashfree_order_id                        String?            @unique
  claim_token                              String?            @unique
  claimed_at                               DateTime?          @db.Timestamp(6)
  claimed_by                               Int?
  created_at                               DateTime           @default(now()) @db.Timestamp(6)
  expires_at                               DateTime           @db.Timestamp(6)
  paid_at                                  DateTime?          @db.Timestamp(6)
  users_checkout_intents_claimed_byTousers users?             @relation("checkout_intents_claimed_byTousers", fields: [claimed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations                            organizations?     @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscription_plans                       subscription_plans @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_checkout_intents_user_idTousers    users?             @relation("checkout_intents_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([email])
  @@index([expires_at])
  @@index([status])
}

model client_feedback {
  id                Int                @id @default(autoincrement())
  application_id    Int
  client_id         Int
  shortlist_id      Int?
  recommendation    String
  notes             String?
  rating            Int?
  created_at        DateTime           @default(now()) @db.Timestamp(6)
  organization_id   Int?
  applications      applications       @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clients           clients            @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations     organizations?     @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  client_shortlists client_shortlists? @relation(fields: [shortlist_id], references: [id], onUpdate: NoAction)

  @@index([application_id])
  @@index([client_id])
  @@index([shortlist_id])
}

model client_shortlist_items {
  id                Int               @id @default(autoincrement())
  shortlist_id      Int
  application_id    Int
  position          Int
  notes             String?
  created_at        DateTime          @default(now()) @db.Timestamp(6)
  organization_id   Int?
  applications      applications      @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations     organizations?    @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  client_shortlists client_shortlists @relation(fields: [shortlist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([application_id])
  @@index([shortlist_id])
}

model client_shortlists {
  id                     Int                      @id @default(autoincrement())
  client_id              Int
  job_id                 Int
  token                  String                   @unique
  title                  String?
  message                String?
  created_by             Int
  created_at             DateTime                 @default(now()) @db.Timestamp(6)
  expires_at             DateTime?                @db.Timestamp(6)
  status                 String                   @default("active")
  organization_id        Int?
  client_feedback        client_feedback[]
  client_shortlist_items client_shortlist_items[]
  clients                clients                  @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  users                    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs                   jobs                     @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations          organizations?           @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([client_id])
  @@index([job_id])
  @@index([token])
}

model clients {
  id                    Int                 @id @default(autoincrement())
  name                  String
  domain                String?
  primary_contact_name  String?
  primary_contact_email String?
  notes                 String?
  created_at            DateTime            @default(now()) @db.Timestamp(6)
  created_by            Int
  organization_id       Int?
  client_feedback       client_feedback[]
  client_shortlists     client_shortlists[]
  users                 users               @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations         organizations?      @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs                  jobs[]

  @@index([created_by])
  @@index([organization_id], map: "clients_org_idx")
}

model co_recruiter_invitations {
  id              Int            @id @default(autoincrement())
  job_id          Int
  email           String
  token           String         @unique(map: "co_recruiter_invite_token_idx")
  invited_by      Int
  inviter_name    String?
  job_title       String?
  expires_at      DateTime       @db.Timestamp(6)
  status          String         @default("pending")
  accepted_at     DateTime?      @db.Timestamp(6)
  created_at      DateTime       @default(now()) @db.Timestamp(6)
  organization_id Int?
  users           users          @relation(fields: [invited_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs            jobs           @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([job_id, email], map: "co_recruiter_invite_job_email_idx")
  @@index([status], map: "co_recruiter_invite_status_idx")
}

model consultants {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  experience   String
  linkedin_url String?
  domains      String
  description  String?
  photo_url    String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @db.Timestamp(6)
}

model contact_submissions {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  phone        String?
  company      String?
  location     String?
  message      String
  submitted_at DateTime @default(now()) @db.Timestamp(6)
}

model domain_claim_requests {
  id                                              Int           @id @default(autoincrement())
  organization_id                                 Int
  domain                                          String
  status                                          String        @default("pending")
  requested_by                                    Int
  requested_at                                    DateTime      @default(now()) @db.Timestamp(6)
  reviewed_by                                     Int?
  reviewed_at                                     DateTime?     @db.Timestamp(6)
  rejection_reason                                String?
  organizations                                   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_domain_claim_requests_requested_byTousers users         @relation("domain_claim_requests_requested_byTousers", fields: [requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_domain_claim_requests_reviewed_byTousers  users?        @relation("domain_claim_requests_reviewed_byTousers", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model email_audit_log {
  id              Int           @id @default(autoincrement())
  application_id  Int?
  template_id     Int?
  template_type   String?
  recipient_email String
  subject         String
  sent_at         DateTime      @default(now()) @db.Timestamp(6)
  sent_by         Int?
  status          String        @default("success")
  error_message   String?
  preview_url     String?
  applications    applications? @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model email_templates {
  id              Int            @id @default(autoincrement())
  name            String
  subject         String
  body            String
  template_type   String
  created_by      Int?
  is_default      Boolean?       @default(false)
  created_at      DateTime       @default(now()) @db.Timestamp(6)
  organization_id Int?
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model form_fields {
  id                    Int                     @id @default(autoincrement())
  form_id               Int
  type                  String
  label                 String
  required              Boolean                 @default(false)
  options               String?
  order                 Int
  forms                 forms                   @relation(fields: [form_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  form_response_answers form_response_answers[]

  @@index([form_id, order])
}

model form_invitations {
  id               Int             @id @default(autoincrement())
  application_id   Int?
  form_id          Int
  token            String          @unique
  expires_at       DateTime        @db.Timestamp(6)
  status           String          @default("pending")
  sent_by          Int
  sent_at          DateTime?       @db.Timestamp(6)
  viewed_at        DateTime?       @db.Timestamp(6)
  answered_at      DateTime?       @db.Timestamp(6)
  field_snapshot   String
  custom_message   String?
  reminder_sent_at DateTime?       @db.Timestamp(6)
  error_message    String?
  created_at       DateTime        @default(now()) @db.Timestamp(6)
  email            String?
  candidate_name   String?
  job_id           Int?
  organization_id  Int?
  applications     applications?   @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  forms            forms           @relation(fields: [form_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs             jobs?           @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations    organizations?  @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users           @relation(fields: [sent_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  form_responses   form_responses?

  @@index([application_id, status], map: "form_invitations_app_status_idx")
  @@index([created_at])
  @@index([email])
  @@index([form_id])
  @@index([job_id])
  @@index([token])
}

model form_response_answers {
  id             Int            @id @default(autoincrement())
  response_id    Int
  field_id       Int
  value          String?
  file_url       String?
  form_fields    form_fields    @relation(fields: [field_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  form_responses form_responses @relation(fields: [response_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([response_id])
}

model form_responses {
  id                    Int                     @id @default(autoincrement())
  invitation_id         Int                     @unique
  application_id        Int
  submitted_at          DateTime                @default(now()) @db.Timestamp(6)
  organization_id       Int?
  form_response_answers form_response_answers[]
  applications          applications            @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  form_invitations      form_invitations        @relation(fields: [invitation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations         organizations?          @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  talent_pool           talent_pool[]

  @@index([application_id])
}

model forms {
  id               Int                @id @default(autoincrement())
  name             String
  description      String?
  is_published     Boolean            @default(true)
  created_by       Int
  created_at       DateTime           @default(now()) @db.Timestamp(6)
  updated_at       DateTime           @default(now()) @db.Timestamp(6)
  organization_id  Int?
  form_fields      form_fields[]
  form_invitations form_invitations[]
  users            users              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations    organizations?     @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by])
  @@index([is_published])
}

model hiring_manager_invitations {
  id           Int       @id @default(autoincrement())
  email        String
  name         String?
  token        String    @unique(map: "hm_invitations_token_idx")
  invited_by   Int
  inviter_name String?
  expires_at   DateTime  @db.Timestamp(6)
  status       String    @default("pending")
  accepted_at  DateTime? @db.Timestamp(6)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  users        users     @relation(fields: [invited_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([email], map: "hm_invitations_email_idx")
  @@index([invited_by], map: "hm_invitations_invited_by_idx")
  @@index([status], map: "hm_invitations_status_idx")
}

model job_analytics {
  id               Int            @id @default(autoincrement())
  job_id           Int
  views            Int            @default(0)
  apply_clicks     Int            @default(0)
  conversion_rate  Decimal?       @default(0.00) @db.Decimal(5, 2)
  ai_score_cache   Int?
  ai_model_version String?
  created_at       DateTime       @default(now()) @db.Timestamp(6)
  updated_at       DateTime       @default(now()) @db.Timestamp(6)
  organization_id  Int?
  jobs             jobs           @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations    organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model job_audit_log {
  id              Int            @id @default(autoincrement())
  job_id          Int
  action          String
  performed_by    Int
  reason          String?
  metadata        Json?
  timestamp       DateTime       @default(now()) @db.Timestamp(6)
  organization_id Int?
  jobs            jobs           @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users          @relation(fields: [performed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([action])
  @@index([job_id])
  @@index([timestamp])
}

model job_recruiters {
  id                                       Int            @id @default(autoincrement())
  job_id                                   Int
  recruiter_id                             Int
  added_by                                 Int?
  added_at                                 DateTime       @default(now()) @db.Timestamp(6)
  organization_id                          Int?
  users_job_recruiters_added_byTousers     users?         @relation("job_recruiters_added_byTousers", fields: [added_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  jobs                                     jobs           @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations                            organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_job_recruiters_recruiter_idTousers users          @relation("job_recruiters_recruiter_idTousers", fields: [recruiter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([job_id, recruiter_id], map: "job_recruiter_unique_idx")
